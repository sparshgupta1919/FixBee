rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users collection
    match /users/{userId} {
      allow read: if true;
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Societies collection
    match /societies/{societyId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Issues collection
    match /issues/{issueId} {
      allow read: if true; // Anyone can read issues (public feed)
      allow create: if isAuthenticated(); // Must be logged in to report
      allow update: if isAuthenticated(); // For upvoting and updating status
      allow delete: if isAuthenticated() && (resource.data.reporterId == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');

      // Issue messages subcollection
      match /messages/{messageId} {
        allow read: if true;
        allow write: if isAuthenticated();
      }
    }

    // Global Posts collection
    match /global_posts/{postId} {
      allow read: if true;
      allow write: if isAuthenticated();

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow write: if isAuthenticated();
      }
    }

    // Notifications collection
    match /notifications/{notificationId} {
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
    }

    // Reports collection (flag/abuse reports submitted by residents)
    // - Any authenticated user can CREATE a report
    // - Only admins can READ, UPDATE (e.g. dismiss/resolve), or DELETE reports
    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    // Chats collection (society group chats)
    match /chats/{chatId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();

      // Messages subcollection inside a chat
      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if isAuthenticated() && (resource.data.senderId == request.auth.uid || isAdmin());
      }
    }
  }
}

